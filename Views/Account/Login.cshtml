@model UserManagementApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <style>
        body, html {
            height: 100%;
            margin: 0;
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-container {
            min-height: 100vh;
            display: flex;
            flex-wrap: wrap;
        }
        .login-form-side {
            flex: 1 1 55%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center; 
            padding: 2rem 3rem;
            position: relative;
        }
        .brand-signature {
            position: absolute;
            top: 2rem;
            left: 3rem;
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 1px;
            line-height: 1.2;
        }

            .brand-signature small {
                display: block;
                font-size: 0.7rem;
                font-weight: 400;
                letter-spacing: 2px;
                color: #6c757d;
                -webkit-text-fill-color: #6c757d;
            }
        .login-card {
            width: 100%;
            max-width: 420px;
            background: white;
            border-radius: 12px;
            padding: 2.5rem;
            box-shadow: 0 8px 30px rgba(0,0,0,0.08);
            margin-top: 3rem; 
        }

            .login-card .subtitle {
                color: #6c757d;
                margin-bottom: 1.5rem;
            }

        .form-check-label {
            font-weight: normal;
        }

        .links a {
            text-decoration: none;
            font-size: 0.9rem;
        }
        .login-illustration {
            flex: 1 1 45%;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .login-illustration img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0.9;
            }
        @@media (max-width: 768px) {
            .login-container {
                flex-direction: column;
            }

            .login-form-side {
                flex: 0 0 auto;
                padding: 1.5rem;
                order: 2;
            }

            .brand-signature {
                position: relative;
                top: auto;
                left: auto;
                margin-bottom: 1rem;
            }

            .login-card {
                margin-top: 0;
            }

            .login-illustration {
                flex: 0 0 auto;
                height: 250px;
                order: 1;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-form-side">
            <div class="brand-signature">
                THÉ APP
                <small>user management</small>
            </div>

            <div class="login-card">
                <h2>Start your journey</h2>
                <p class="subtitle">Sign In to The App</p>

                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl))
                    {
                        <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />
                    }

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <input asp-for="Email" class="form-control" placeholder="test@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe" value="true" />
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Sign In</button>
                    </div>
                </form>

                <div class="links d-flex justify-content-between">
                    <a asp-action="Register" asp-controller="Account">Don't have an account? <strong>Sign up</strong></a>
                    <a href="#">Forgot password?</a>
                </div>
            </div>
        </div>

        <div class="login-illustration">
            <img src="/images/illustration.jpg" alt="Illustration" />
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>